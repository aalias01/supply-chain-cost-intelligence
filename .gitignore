__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Environment
.env
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# Tableau / PowerBI source (only export PDFs/screenshots)
*.twb
*.twbx
*.pbix
